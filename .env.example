# 사용할 증권사 어댑터: toss | kis | mock
BROKERAGE=mock
PORT=3000

# ───────────────────────────────────────────
# 토스증권 OpenAPI (https://openapi.tossinvest.com)
# ───────────────────────────────────────────
TOSS_CLIENT_ID=your_client_id
TOSS_CLIENT_SECRET=your_client_secret
# TOSS_BASE_URL=https://openapi.tossinvest.com

# ───────────────────────────────────────────
# 한국투자증권 OpenAPI (https://apiportal.koreainvestment.com)
# ───────────────────────────────────────────
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
# KIS_PAPER=false   # true 로 설정하면 모의투자 환경 사용
# KIS_BASE_URL=     # 미설정 시 실전/모의에 따라 자동 선택
